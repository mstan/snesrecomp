@@ -168,6 +170,12 @@ void S9xMainLoop (void)
 				Opcodes = S9xOpcodesSlow;
 		}
 
+		/* Oracle per-instruction hook. Captures PB:PC and the opcode
+		 * byte right before dispatch, so the bridge can record full
+		 * register state (Registers/CPU read directly) for trace.
