diff --git a/nall/primitives/integer.hpp b/nall/primitives/integer.hpp
index 92e6e89..252fa40 100644
--- a/nall/primitives/integer.hpp
+++ b/nall/primitives/integer.hpp
@@ -12,8 +12,9 @@ template<uint Precision> struct Integer {
     conditional_t<bits() <= 64, int64_t,
     void>>>>;
   using utype = typename Natural<Precision>::utype;
-  static inline constexpr auto mask() -> utype { return ~0ull >> 64 - Precision; }
-  static inline constexpr auto sign() -> utype { return 1ull << Precision - 1; }
+  // snesrecomp: reformulated to dodge a GCC 15 constexpr ICE; value-identical.
+  static inline constexpr auto mask() -> utype { return Precision >= 64 ? (utype)~0ull : (utype)(((uint64_t)1 << Precision) - 1); }
+  static inline constexpr auto sign() -> utype { return (utype)((uint64_t)1 << (Precision - 1)); }
 
   inline Integer() : data(0) {}
   template<uint Bits> inline Integer(Integer<Bits> value) { data = cast(value); }
diff --git a/nall/primitives/natural.hpp b/nall/primitives/natural.hpp
index 7bf3237..bedb006 100644
--- a/nall/primitives/natural.hpp
+++ b/nall/primitives/natural.hpp
@@ -11,7 +11,9 @@ template<uint Precision> struct Natural {
     conditional_t<bits() <= 32, uint32_t,
     conditional_t<bits() <= 64, uint64_t,
     void>>>>;
-  static inline constexpr auto mask() -> utype { return ~0ull >> 64 - Precision; }
+  // snesrecomp: reformulated from `~0ull >> 64 - Precision` to dodge a GCC 15
+  // constexpr ICE (segfault) on this idiom; value-identical.
+  static inline constexpr auto mask() -> utype { return Precision >= 64 ? (utype)~0ull : (utype)(((uint64_t)1 << Precision) - 1); }
 
   inline Natural() : data(0) {}
   template<uint Bits> inline Natural(Natural<Bits> value) { data = cast(value); }
