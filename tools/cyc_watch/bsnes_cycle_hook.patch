+  g_bsnes_total_cpu_cycles++;
+  bsnes_mmio_on_write(address, data);   // Axis-4 MMIO write log (dev-only)
   aluEdge();
 
   if(address & 0x408000) {
diff --git a/bsnes/sfc/cpu/timing.cpp b/bsnes/sfc/cpu/timing.cpp
index 987c0dd..f418e8f 100644
--- a/bsnes/sfc/cpu/timing.cpp
+++ b/bsnes/sfc/cpu/timing.cpp
@@ -8,8 +8,17 @@ auto CPU::joypadCounter() const -> uint {
   return counter.cpu & 255;
 }
 
+//snesrecomp Axis-2 cycle hook (dev-only): monotonic master-clock accumulator.
+//Every 2 master clocks the CPU thread consumes (CPU + DMA/HDMA, which also
+//step the CPU thread) funnel through stepOnce, so this is the cumulative
+//guest master-clock count — the analog of psx Beetle's
+//beetle_total_guest_cycles. Defined in target-libretro/libretro.cpp and
+//exported as bsnes_total_guest_cycles().
+extern "C" uint64_t g_bsnes_total_master_cycles;
+
 auto CPU::stepOnce() -> void {
   counter.cpu += 2;
+  g_bsnes_total_master_cycles += 2;
   tick();
   if(hcounter() & 2) nmiPoll(), irqPoll();
   if(joypadCounter() == 0) joypadEdge();
diff --git a/bsnes/target-libretro/libretro.cpp b/bsnes/target-libretro/libretro.cpp
index 8010816..eb23b55 100644
--- a/bsnes/target-libretro/libretro.cpp
+++ b/bsnes/target-libretro/libretro.cpp
@@ -1,6 +1,98 @@
 #include <cassert>
+#include <cstdint>
 #include "libretro.h"
 
+// snesrecomp Axis-2 cycle hook (dev-only). Monotonic guest master-clock
+// counter, incremented in SuperFamicom::CPU::stepOnce (sfc/cpu/timing.cpp)
+// and exported for the snesref oracle frontend. The two-anchor REGION diff
+// reads this at guest-PC anchors; the absolute origin is irrelevant (offset
+// cancels), but bsnes_reset_guest_cycles() / retro_reset zero it for clean
+// runs. NOTE: keep overclocking OFF so every CPU cycle is counted.
+// PE/mingw selects exports by __declspec(dllexport) (the version-script only
+// localizes; it does not ADD exports), so mark these explicitly.
+#if defined(_WIN32)
+  #define BSNES_HOOK_EXPORT __declspec(dllexport)
+#else
+  #define BSNES_HOOK_EXPORT __attribute__((visibility("default")))
+#endif
+extern "C" uint64_t g_bsnes_total_master_cycles = 0;  // C linkage: shared with sfc/cpu/timing.cpp
+extern "C" BSNES_HOOK_EXPORT uint64_t bsnes_total_guest_cycles(void) {
+	return g_bsnes_total_master_cycles;
+}
+
+// CPU (bus + internal) cycle counter — the unit the recomp/authority model
+// emits (master clocks weight 6/8/12 per access and aren't directly
+// comparable). Incremented once per CPU::idle/read/write (sfc/cpu/memory.cpp).
+extern "C" uint64_t g_bsnes_total_cpu_cycles = 0;
+// Two-anchor REGION latch: set anchor guest-PCs (PB:PC), and the first time
+// the CPU fetches an instruction at each (sfc/cpu/cpu.cpp CPU::main), latch the
+// CPU-cycle count. Region delta = latch[1] - latch[0]. -1 anchor = disabled.
+extern "C" uint32_t g_bsnes_cyc_anchor[2]  = {0xFFFFFFFFu, 0xFFFFFFFFu};
+extern "C" uint64_t g_bsnes_anchor_latch[2] = {0, 0};
+extern "C" uint8_t  g_bsnes_anchor_hit[2]   = {0, 0};
+
+extern "C" BSNES_HOOK_EXPORT uint64_t bsnes_total_cpu_cycles(void) {
+	return g_bsnes_total_cpu_cycles;
+}
+extern "C" BSNES_HOOK_EXPORT void bsnes_set_cyc_anchor(int idx, uint32_t pc24) {
+	if (idx == 0 || idx == 1) {
+		g_bsnes_cyc_anchor[idx] = pc24;
+		g_bsnes_anchor_hit[idx] = 0;
+		g_bsnes_anchor_latch[idx] = 0;
+	}
+}
+extern "C" BSNES_HOOK_EXPORT uint64_t bsnes_get_anchor_cpu_cycles(int idx) {
+	return (idx == 0 || idx == 1) ? g_bsnes_anchor_latch[idx] : 0;
+}
+extern "C" BSNES_HOOK_EXPORT int bsnes_anchor_hit(int idx) {
+	return (idx == 0 || idx == 1) ? (int)g_bsnes_anchor_hit[idx] : 0;
+}
+
+extern "C" BSNES_HOOK_EXPORT void bsnes_reset_guest_cycles(void) {
+	g_bsnes_total_master_cycles = 0;
+	g_bsnes_total_cpu_cycles = 0;
+	g_bsnes_anchor_hit[0] = g_bsnes_anchor_hit[1] = 0;
+	g_bsnes_anchor_latch[0] = g_bsnes_anchor_latch[1] = 0;
+}
+
+// snesrecomp Axis-4: MMIO register-write log (dev-only). Records (frame,
+// addr16, val) for CPU writes whose low-16 address is in [lo,hi], excluding
+// WRAM banks $7E/$7F (where $4200 etc. are RAM, not MMIO). The probe sets the
+// frame index before each retro_run; the recomp's get_reg_trace produces the
+// same (frame,adr,val) stream, and an offline aligner diffs the two.
+#define BSNES_MMIO_LOG_CAP 262144u
+struct BsnesMmioEntry { int frame; unsigned short addr; unsigned char val; };
+static BsnesMmioEntry g_bsnes_mmio_log[BSNES_MMIO_LOG_CAP];
+static unsigned g_bsnes_mmio_count = 0;
+static unsigned g_bsnes_mmio_lo = 0xFFFFu, g_bsnes_mmio_hi = 0u;   // empty until armed
+static int      g_bsnes_mmio_frame = 0;
+
+extern "C" void bsnes_mmio_on_write(uint32_t address, uint8_t data) {
+	unsigned bank = (address >> 16) & 0xFF;
+	if(bank == 0x7E || bank == 0x7F) return;          // WRAM, not MMIO
+	unsigned lo16 = address & 0xFFFF;
+	if(lo16 < g_bsnes_mmio_lo || lo16 > g_bsnes_mmio_hi) return;
+	if(g_bsnes_mmio_count >= BSNES_MMIO_LOG_CAP) return;
+	BsnesMmioEntry &e = g_bsnes_mmio_log[g_bsnes_mmio_count++];
+	e.frame = g_bsnes_mmio_frame;
+	e.addr  = (unsigned short)lo16;
+	e.val   = data;
+}
+extern "C" BSNES_HOOK_EXPORT void bsnes_mmio_arm(uint32_t lo, uint32_t hi) {
+	g_bsnes_mmio_lo = lo; g_bsnes_mmio_hi = hi;
+	g_bsnes_mmio_count = 0; g_bsnes_mmio_frame = 0;
+}
+extern "C" BSNES_HOOK_EXPORT void bsnes_mmio_set_frame(int f) { g_bsnes_mmio_frame = f; }
+extern "C" BSNES_HOOK_EXPORT uint32_t bsnes_mmio_count(void) { return g_bsnes_mmio_count; }
+extern "C" BSNES_HOOK_EXPORT int bsnes_mmio_get(uint32_t i, int *frame,
+                                                uint32_t *addr, uint32_t *val) {
+	if(i >= g_bsnes_mmio_count) return 0;
+	*frame = g_bsnes_mmio_log[i].frame;
+	*addr  = g_bsnes_mmio_log[i].addr;
+	*val   = g_bsnes_mmio_log[i].val;
+	return 1;
+}
+
 static retro_environment_t environ_cb;
 static retro_video_refresh_t video_cb;
 static retro_audio_sample_t audio_cb;
@@ -605,6 +697,7 @@ RETRO_API void retro_set_controller_port_device(unsigned port, unsigned device)
 
 RETRO_API void retro_reset()
 {
+	bsnes_reset_guest_cycles();        // Axis-2 hook: clean origin per reset
 	emulator->reset();
 }
 
