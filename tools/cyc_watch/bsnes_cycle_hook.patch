diff --git a/bsnes/sfc/cpu/cpu.cpp b/bsnes/sfc/cpu/cpu.cpp
index b6fec16..27862c8 100644
--- a/bsnes/sfc/cpu/cpu.cpp
+++ b/bsnes/sfc/cpu/cpu.cpp
@@ -10,6 +10,13 @@ CPU cpu;
 #include "irq.cpp"
 #include "serialization.cpp"
 
+// snesrecomp Axis-2 REGION anchor globals (defined in target-libretro/
+// libretro.cpp). extern "C" so they resolve to the same symbols.
+extern "C" uint32_t g_bsnes_cyc_anchor[2];
+extern "C" uint64_t g_bsnes_anchor_latch[2];
+extern "C" uint8_t  g_bsnes_anchor_hit[2];
+extern "C" uint64_t g_bsnes_total_cpu_cycles;
+
 auto CPU::synchronizeSMP() -> void {
   if(smp.clock < 0) scheduler.resume(smp.thread);
 }
@@ -32,6 +39,28 @@ auto CPU::Enter() -> void {
 }
 
 auto CPU::main() -> void {
+  // snesrecomp Axis-2: latch the CPU-cycle count at each REGION anchor PC
+  // (PB:PC). r.pc.d is the 24-bit PC of the about-to-execute instruction, so
+  // the latch holds cycles consumed *before* it — exactly the region boundary.
+  // TIGHT ordered latch: anchor[0]=start updates on EVERY start hit (so the
+  // LAST start before the end wins), anchor[1]=end freezes on its first hit
+  // after a start has been seen. Taking the last start isolates the adjacent
+  // start->end EDGE even when start sits in a loop (e.g. a self-looping block
+  // whose conditional branch exits to end) — the recomp ring measures exactly
+  // that single edge. Subsumes plain ordered latch for forward/backward/
+  // non-adjacent regions. (Globals in target-libretro/libretro.cpp.)
+  {
+    uint32_t _pc = (uint32_t)(r.pc.d & 0xFFFFFF);
+    if(!g_bsnes_anchor_hit[1] && _pc == g_bsnes_cyc_anchor[0]) {
+      g_bsnes_anchor_latch[0] = g_bsnes_total_cpu_cycles;
+      g_bsnes_anchor_hit[0] = 1;
+    }
+    if(g_bsnes_anchor_hit[0] && !g_bsnes_anchor_hit[1]
+       && _pc == g_bsnes_cyc_anchor[1]) {
+      g_bsnes_anchor_latch[1] = g_bsnes_total_cpu_cycles;
+      g_bsnes_anchor_hit[1] = 1;
+    }
+  }
   if(r.wai) return instructionWait();
   if(r.stp) return instructionStop();
   if(!status.interruptPending) return instruction();
